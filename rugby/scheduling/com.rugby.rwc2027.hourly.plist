<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rugby.rwc2027.hourly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>REPLACE_WITH_SCRIPT_PATH</string>
    </array>

    <!-- Fire every hour. If the Mac was asleep at a fire time, launchd runs
         the job once shortly after wake, so overnight gaps self-heal. -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <!-- Also run immediately when the job is loaded / on login. -->
    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>REPLACE_WITH_HOME/Library/Logs/rwc-trigger.out.log</string>
    <key>StandardErrorPath</key>
    <string>REPLACE_WITH_HOME/Library/Logs/rwc-trigger.err.log</string>
</dict>
</plist>
